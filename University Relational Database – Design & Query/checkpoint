-- STEP 4 - QUERY EXECUTION

-- QUERY 1: Retrieve all students enrolled in the course "Database Systems"
SELECT '=== QUERY 1: Students enrolled in Database Systems ===' AS '';

SELECT s.student_id, s.name, s.email, e.grade
FROM Students s
JOIN Enrollments e ON s.student_id = e.student_id
JOIN Courses c ON e.course_id = c.course_id
WHERE c.title = 'Database Systems';


-- QUERY 2: List all courses along with the names of their instructors
SELECT '=== QUERY 2: All courses and their instructors ===' AS '';

SELECT c.course_id, c.title, c.credits, i.name AS instructor_name, i.department
FROM Courses c
JOIN Instructors i ON c.instructor_id = i.instructor_id
ORDER BY c.course_id;

-- QUERY 3: Find students who are not enrolled in any course
SELECT '=== QUERY 3: Students with no enrollments ===' AS '';

SELECT s.student_id, s.name, s.email, s.age
FROM Students s
LEFT JOIN Enrollments e ON s.student_id = e.student_id
WHERE e.student_id IS NULL;



