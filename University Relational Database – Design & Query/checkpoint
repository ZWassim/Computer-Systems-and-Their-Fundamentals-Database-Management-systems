-- QUERY 5: Delete a course by its ID
-- Note: Due to ON DELETE CASCADE on Enrollments, deleting a course will
-- automatically delete its enrollment records.
-- Also, ON DELETE RESTRICT on Courses -> Instructors prevents deleting an
-- instructor who teaches courses (safety).

SELECT '=== Before course deletion: Courses list ===' AS '';
SELECT * FROM Courses;

SELECT '=== Before course deletion: Enrollments in course 203 ===' AS '';
SELECT * FROM Enrollments WHERE course_id = 203;

-- Delete course with ID = 203 (Data Structures)
DELETE FROM Courses WHERE course_id = 203;

SELECT '=== After course deletion: Courses list ===' AS '';
SELECT * FROM Courses;

SELECT '=== After course deletion: Enrollments (none for course 203) ===' AS '';
SELECT * FROM Enrollments;

