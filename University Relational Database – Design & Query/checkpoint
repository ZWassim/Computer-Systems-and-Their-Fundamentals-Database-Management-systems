
-- STEP 1 - SCHEMA DESIGN (Relational Schema with Normalization up to 3NF)

/*
Normalization Analysis:

1NF (First Normal Form):
- All attributes contain atomic values (no repeating groups or arrays).
- Each table has a primary key.

2NF (Second Normal Form):
- All non-key attributes fully depend on the entire primary key.
- Enrollments table: student_id and course_id together determine grade.
- No partial dependencies.

3NF (Third Normal Form):
- No transitive dependencies (non-key attributes depend only on the primary key).
- In Students: name, email, age depend only on student_id (no transitive dependency).
- In Courses: title, credits, instructor_id depend only on course_id.
- In Instructors: name, department depend only on instructor_id.

Final Schema (3NF compliant):
---------------------
Students (student_id, name, email, age)
Courses (course_id, title, credits, instructor_id)
Instructors (instructor_id, name, department)
Enrollments (student_id, course_id, grade)

Constraints:
- Primary keys: student_id, course_id, instructor_id, (student_id, course_id) composite
- Foreign keys: Enrollments references Students and Courses; Courses references Instructors
- CHECK: age > 17, credits >= 0, credits <= 12, grade IN ('A','B','C','D','F',...)
- NOT NULL: all key fields and required fields
- UNIQUE: email
*/

-- STEP 2 - SQL TABLE CREATION

-- Drop tables if they exist (for clean re-run)
DROP TABLE IF EXISTS Enrollments;
DROP TABLE IF EXISTS Courses;
DROP TABLE IF EXISTS Instructors;
DROP TABLE IF EXISTS Students;

-- Create Instructors table (referenced by Courses)
CREATE TABLE Instructors (
    instructor_id INT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    department VARCHAR(100) NOT NULL,
    email VARCHAR(100) UNIQUE,
    CONSTRAINT chk_instructor_name CHECK (LENGTH(TRIM(name)) > 0)
);

-- Create Students table
CREATE TABLE Students (
    student_id INT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    email VARCHAR(100) NOT NULL UNIQUE,
    age INT NOT NULL,
    CONSTRAINT chk_student_age CHECK (age > 17),
    CONSTRAINT chk_student_name CHECK (LENGTH(TRIM(name)) > 0)
);

-- Create Courses table (references Instructors)
CREATE TABLE Courses (
    course_id INT PRIMARY KEY,
    title VARCHAR(200) NOT NULL,
    credits INT NOT NULL,
    instructor_id INT NOT NULL,
    CONSTRAINT chk_credits CHECK (credits >= 0 AND credits <= 12),
    FOREIGN KEY (instructor_id) REFERENCES Instructors(instructor_id)
        ON DELETE RESTRICT ON UPDATE CASCADE
);

-- Create Enrollments table (junction table between Students and Courses)
CREATE TABLE Enrollments (
    student_id INT NOT NULL,
    course_id INT NOT NULL,
    grade CHAR(2),
    enrollment_date DATE DEFAULT CURRENT_DATE,
    PRIMARY KEY (student_id, course_id),
    FOREIGN KEY (student_id) REFERENCES Students(student_id)
        ON DELETE CASCADE ON UPDATE CASCADE,
    FOREIGN KEY (course_id) REFERENCES Courses(course_id)
        ON DELETE CASCADE ON UPDATE CASCADE,
    CONSTRAINT chk_grade CHECK (grade IN ('A', 'A-', 'B+', 'B', 'B-', 'C+', 'C', 'C-', 'D', 'F', 'P', 'NP', NULL))
);

